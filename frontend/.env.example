# Frontend Environment Configuration

# API Base URL
# - For development (separate servers): http://localhost:8000
# - For Heroku/production: Leave unset or empty (uses same-origin requests)
# - For other deployments: Set to your API domain (e.g., https://api.example.com)
VITE_API_BASE_URL=http://localhost:8000

# Environment
# - development: Development mode with hot reload
# - production: Optimized build
VITE_NODE_ENV=development

