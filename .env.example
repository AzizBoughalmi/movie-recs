# Movie Recommendations Platform - Environment Variables
# Copy this file to .env and fill in your actual values

# ============ REQUIRED API KEYS ============

# TMDB API Key - Required for movie/series search
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Gemini API Key - Required for AI recommendations
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LangSearch API Key - Required for web search functionality
# Get from your LangSearch provider
LANGSEARCH_API_KEY=your_langsearch_api_key_here

# ============ SECURITY ============

# Session Secret Key - MUST be a long random string for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# ============ API CONFIGURATION ============

# API Base URL - Leave empty or unset for production (same-origin)
# Development: http://localhost:8000
# Production (Heroku): Leave empty or unset
API_BASE_URL=http://localhost:8000

# Frontend URL - Leave empty or unset for production (same-origin)
# Development: http://localhost:5173
# Production (Heroku): Leave empty or unset
FRONTEND_URL=http://localhost:5173

# ============ LOGGING ============

# Log level for application logging
LOG_LEVEL=DEBUG

# Whether to log to file (not recommended for Heroku)
LOG_TO_FILE=false

# ============ DEPLOYMENT NOTES ============

# For Heroku Deployment:
# 1. Set config vars with: heroku config:set KEY=VALUE
# 2. Only set TMDB_API_KEY, GEMINI_API_KEY, LANGSEARCH_API_KEY, and SECRET_KEY
# 3. Leave API_BASE_URL and FRONTEND_URL unset (both served from same domain)
# 4. Frontend will use same-origin requests (no VITE_API_BASE_URL needed)
#
# Example:
#   heroku config:set TMDB_API_KEY=xxx GEMINI_API_KEY=yyy LANGSEARCH_API_KEY=zzz SECRET_KEY=abc123
#
# For development:
# - Backend: Set API_BASE_URL=http://localhost:8000 and FRONTEND_URL=http://localhost:5173
# - Frontend: Set VITE_API_BASE_URL=http://localhost:8000
#
# For other deployments (separate domains):
# - Backend: Set API_BASE_URL and FRONTEND_URL to your actual domains
# - Frontend: Set VITE_API_BASE_URL to your backend API domain
